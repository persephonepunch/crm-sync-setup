{%- comment -%}
============================================================================
  CRM Sync · UIkit responsive navbar for design-sync.myshopify.com
  Renders the Shopify Menu (linklists) as a UIkit navbar with an offcanvas
  drawer on mobile. Monochrome + cyan accent, Roboto / Roboto Mono.

  PASTE IN TWO PLACES — the loader goes in the <head> (the "helmet"),
  the markup goes in the body:

  1) HEAD  → Online Store → Themes → Edit code → theme.liquid, inside <head>
             (or Theme settings → Custom Code → Head).  Everything in
             PART 1 below (fonts + UIkit CSS + deferred UIkit JS + theme CSS).

  2) BODY  → where the nav should render — a section, a Custom Liquid block
             at the top of the layout, or theme.liquid right after <body>.
             Everything in PART 2 below.

  Menu handle: change 'main-menu' if your Shopify navigation uses another
  handle (Shopify admin → Content → Menus).
============================================================================
{%- endcomment -%}

{%- comment -%} ==================== PART 1 · HEAD (helmet) ====================
  LAYER 2 · Look  = fonts + UIkit CSS + the theme override below.
  LAYER 1 · Behavior = the Higher-Order Stack loader (stack-loader.js): it
    brings GA4 (Tier A, Consent-Mode-v2, pulled from the Config app — NOT
    hardcoded) + UIkit JS (Tier B, via data-use). The Brand Designer loads
    the SAME file with data-use="uikit,petite-vue,gsap".
  The GA4 measurement ID is read from the worker Config (per-shop KV); the
  Measurement Protocol secret stays server-side under the Key Ceremony.
{%- endcomment -%}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Roboto:wght@100;300;400;500;700&family=Roboto+Mono:wght@400;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/uikit@3.21.6/dist/css/uikit.min.css">
<!-- Higher-Order Stack loader — served FROM THE WORKER (updates ship with a deploy).
     window.crmStack: Consent-Mode-v2 (GA4 id pulled from /stack/config per-shop),
     event bus, UIkit JS via data-stack. Same loader the Brand Designer uses. -->
<script defer
  src="https://cf-worker-crm-sync.yoonsunlee150.workers.dev/embed/stack-loader.js"
  data-stack="uikit"
  data-worker="https://cf-worker-crm-sync.yoonsunlee150.workers.dev"
  data-shop="{{ shop.permanent_domain }}"></script>
<!-- CRM + PIM component bundles (worker-served, per-need). CRM registers <crm-*>;
     PIM registers <pim-*> + GID⇄Webflow⇄Xano resolve. -->
<script defer src="https://cf-worker-crm-sync.yoonsunlee150.workers.dev/embed/crm-elements.js"></script>
<script defer src="https://cf-worker-crm-sync.yoonsunlee150.workers.dev/embed/pim-elements.js"></script>
<!-- Docs modal (window.crmDocsModal) — docs utility hosted with the docs content. -->
<script defer
  src="https://persephonepunch.github.io/crm-sync-setup/docs-nav.js"
  data-modal-only
  data-docs-base="https://persephonepunch.github.io/crm-sync-setup/"></script>
<style>
  /* theme override — scoped to .crm-nav / #crm-nav-offcanvas so it can't clobber the theme */
  .crm-nav{--cyan:#06b6d4}
  .crm-nav .uk-navbar-container{background:#fff;border-bottom:1px solid #e6e6e6;font-family:"Roboto",-apple-system,system-ui,sans-serif}
  .crm-nav .uk-navbar-nav{flex-wrap:nowrap}
  /* utils cluster right-justified; the CTA may wrap to a second row when tight */
  .crm-nav .uk-navbar-right{flex-wrap:wrap;justify-content:flex-end;align-items:center;row-gap:6px;gap:2px}
  .crm-nav .uk-navbar-center .uk-navbar-nav{justify-content:center}
  .crm-nav .uk-logo{display:flex;align-items:center;gap:8px;white-space:nowrap;font-family:"Roboto Mono",ui-monospace,Menlo,monospace;
    font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:#0a0a0a;font-size:14px}
  .crm-nav .uk-logo .mark{width:22px;height:22px;border:1.5px solid #0a0a0a;background:#cfe9f4;
    display:inline-flex;align-items:center;justify-content:center;font-size:8px;letter-spacing:.02em}
  .crm-nav .uk-navbar-nav>li>a{font-family:"Roboto",sans-serif;font-size:13.5px;letter-spacing:0;
    text-transform:none;color:#5c5c5c;min-height:56px;padding:0 9px;border-bottom:2px solid transparent}
  .crm-nav .uk-navbar-nav>li>a:hover,.crm-nav .uk-navbar-nav>li.uk-active>a{color:#0a0a0a;border-bottom-color:var(--cyan)}
  .crm-nav .crm-nav-login{color:#5c5c5c;font-size:13.5px;padding:0 8px}
  .crm-nav .crm-nav-login:hover{color:#0a0a0a}
  .crm-nav .crm-nav-search{color:#0a0a0a;padding:0 7px}
  .crm-nav .crm-nav-search:hover{color:var(--cyan)}
  .crm-nav .crm-nav-cart{position:relative;color:#0a0a0a;padding:0 7px}
  .crm-nav .crm-nav-cart:hover{color:var(--cyan)}
  .crm-nav .crm-nav-cart-count{position:absolute;top:12px;right:0;min-width:16px;height:16px;
    display:inline-flex;align-items:center;justify-content:center;background:var(--cyan);color:#fff;
    font:600 10px/1 "Roboto Mono",monospace;border-radius:9px;padding:0 4px}
  .crm-nav .crm-nav-cart-count[hidden]{display:none}
  #crm-nav-offcanvas .crm-nav-cart{color:#0a0a0a}
  .crm-nav-cta{background:#0a0a0a;color:#fff;border:1.5px solid #0a0a0a;border-radius:2px;font-family:"Roboto",sans-serif;
    font-weight:600;text-transform:none;font-size:13px;line-height:30px;padding:0 12px}
  .crm-nav-cta:hover{background:#fff;color:#0a0a0a}
  .crm-nav .uk-navbar-toggle{color:#0a0a0a;padding:0 4px}
  /* offcanvas drawer — light theme to match the site */
  #crm-nav-offcanvas .uk-offcanvas-bar{background:#fff;color:#0a0a0a;border-left:1.5px solid #0a0a0a;font-family:"Roboto",sans-serif}
  #crm-nav-offcanvas .uk-nav-header{color:#5c5c5c;font-family:"Roboto Mono",monospace;letter-spacing:.2em;font-size:11px}
  #crm-nav-offcanvas .uk-nav-default>li>a{color:#0a0a0a;font-size:16px;padding:14px 0;border-bottom:1px solid #e6e6e6}
  #crm-nav-offcanvas .uk-nav-default>li>a:hover{color:var(--cyan)}
  #crm-nav-offcanvas .uk-nav-default>li.uk-active>a{color:#0a0a0a}
  #crm-nav-offcanvas .uk-offcanvas-close{color:#0a0a0a}
  #crm-nav-offcanvas .uk-nav-default>li>a.crm-nav-cta{display:block;text-align:center;margin-top:16px;
    line-height:44px;background:#0a0a0a;color:#fff}
  #crm-nav-offcanvas .uk-nav-default>li>a.crm-nav-cta:hover{background:#0a0a0a;color:#fff}
</style>

{%- comment -%} ==================== PART 2 · BODY (markup) ==================== {%- endcomment -%}
<div class="crm-nav">
  <nav class="uk-navbar-container uk-navbar-transparent"
       role="navigation" aria-label="Primary" data-crm-region="primary-nav">
   <div class="uk-container uk-container-xlarge">
    <div uk-navbar="align: left">
    <div class="uk-navbar-left">
      <a class="uk-navbar-item uk-logo" href="{{ routes.root_url }}">
        <span class="mark">CRM</span> {{ shop.name | default: 'CRM Sync' }}
      </a>
    </div>
    <div class="uk-navbar-center uk-visible@m">
      <ul class="uk-navbar-nav">
        {%- for link in linklists['main-menu'].links -%}
          <li{% if link.active %} class="uk-active"{% endif %}><a href="{{ link.url }}">{{ link.title }}</a></li>
        {%- endfor -%}
        <li><a href="#docs" onclick="if(window.crmDocsModal){event.preventDefault();window.crmDocsModal.open(0);}">Docs</a></li>
      </ul>
    </div>
    <div class="uk-navbar-right">
      <a id="crm-nav-search" class="crm-nav-search uk-navbar-item uk-visible@m" href="{{ routes.search_url }}" aria-label="Search" role="search" data-crm-role="search"><span uk-icon="icon: search"></span></a>
      <a id="crm-nav-cart" class="crm-nav-cart uk-navbar-item uk-visible@m" href="{{ routes.cart_url }}" aria-label="Cart" data-crm-role="cart">
        <span uk-icon="icon: cart"></span>
        <span class="crm-nav-cart-count" data-cart-count{% if cart.item_count == 0 %} hidden{% endif %}>{{ cart.item_count }}</span>
      </a>
      <a id="crm-nav-login" class="crm-nav-login uk-visible@m" data-crm-role="login" href="{{ routes.account_login_url }}">Log in</a>
      <a class="uk-button crm-nav-cta uk-visible@m uk-margin-small-left" href="{{ routes.root_url }}pages/connect-a-segment">Connect a segment</a>
      <a class="uk-navbar-toggle uk-hidden@m" href="#crm-nav-offcanvas" uk-toggle uk-navbar-toggle-icon aria-label="Open menu"></a>
    </div>
    </div>
   </div>
  </nav>

  <div id="crm-nav-offcanvas" uk-offcanvas="overlay: true; flip: true">
    <div class="uk-offcanvas-bar">
      <button class="uk-offcanvas-close" type="button" uk-close aria-label="Close menu"></button>
      <ul class="uk-nav uk-nav-default">
        <li class="uk-nav-header">Menu</li>
        {%- for link in linklists['main-menu'].links -%}
          <li{% if link.active %} class="uk-active"{% endif %}><a href="{{ link.url }}">{{ link.title }}</a></li>
        {%- endfor -%}
        <li><a href="#docs" onclick="if(window.crmDocsModal){event.preventDefault();UIkit.offcanvas('#crm-nav-offcanvas').hide();window.crmDocsModal.open(0);}">Docs</a></li>
        <li><a id="crm-nav-search-m" class="crm-nav-search" href="{{ routes.search_url }}"><span uk-icon="icon: search"></span> Search</a></li>
        <li><a id="crm-nav-cart-m" class="crm-nav-cart" href="{{ routes.cart_url }}"><span uk-icon="icon: cart"></span> Cart (<span data-cart-count>{{ cart.item_count }}</span>)</a></li>
        <li><a id="crm-nav-login-m" class="crm-nav-login" href="{{ routes.account_login_url }}">Log in</a></li>
        <li><a class="uk-button crm-nav-cta" href="{{ routes.root_url }}pages/connect-a-segment">Connect a segment</a></li>
      </ul>
    </div>
  </div>
</div>

{%- comment -%} ============================================================================
  PART 2b · ALT MENU SOURCE — Webflow → Shopify Nav Collection (embed code)

  Use this INSTEAD of the linklists markup above when the menu is authored in a
  Webflow CMS "Nav" collection and synced Webflow → Shopify. The items are
  fetched as JSON from the worker and bound reactively with petite-vue (Tier B
  of the Higher-Order Stack) into the SAME UIkit navbar — so the look/behavior
  is identical; only the data source changes. UIkit auto-inits the rendered
  markup; the Docs modal / Log in / CTA are unchanged.

  Worker feed shape (GET, per-shop):
    { "items": [ { "title": "Difference", "url": "/pages/difference", "active": false }, … ] }
============================================================================ {%- endcomment -%}
{%- comment -%}  --- uncomment to switch to the Webflow-collection source ---
<div class="crm-nav" v-scope="Nav()" @mounted="load">
  <nav class="uk-navbar-container uk-navbar-transparent"
       role="navigation" aria-label="Primary" data-crm-region="primary-nav">
   <div class="uk-container uk-container-xlarge">
    <div uk-navbar="align: left">
    <div class="uk-navbar-left">
      <a class="uk-navbar-item uk-logo" href="{{ routes.root_url }}"><span class="mark">CRM</span> {{ shop.name }}</a>
    </div>
    <div class="uk-navbar-right">
      <ul class="uk-navbar-nav uk-visible@m">
        <li v-for="i in items" :class="{ 'uk-active': i.active }"><a :href="i.url" v-text="i.title"></a></li>
        <li><a href="#docs" @click.prevent="openDocs">Docs</a></li>
      </ul>
      <a id="crm-nav-search" class="crm-nav-search uk-navbar-item uk-visible@m" href="{{ routes.search_url }}" aria-label="Search" role="search" data-crm-role="search"><span uk-icon="icon: search"></span></a>
      <a id="crm-nav-cart" class="crm-nav-cart uk-navbar-item uk-visible@m" href="{{ routes.cart_url }}" aria-label="Cart" data-crm-role="cart">
        <span uk-icon="icon: cart"></span>
        <span class="crm-nav-cart-count" data-cart-count{% if cart.item_count == 0 %} hidden{% endif %}>{{ cart.item_count }}</span>
      </a>
      <a id="crm-nav-login" class="crm-nav-login uk-visible@m" data-crm-role="login" href="{{ routes.account_login_url }}">Log in</a>
      <a class="uk-button crm-nav-cta uk-visible@m uk-margin-small-left" href="{{ routes.root_url }}pages/connect-a-segment">Connect a segment</a>
      <a class="uk-navbar-toggle uk-hidden@m" href="#crm-nav-offcanvas" uk-toggle uk-navbar-toggle-icon aria-label="Open menu"></a>
    </div>
    </div>
   </div>
  </nav>
  <div id="crm-nav-offcanvas" uk-offcanvas="overlay: true; flip: true">
    <div class="uk-offcanvas-bar">
      <button class="uk-offcanvas-close" type="button" uk-close></button>
      <ul class="uk-nav uk-nav-default">
        <li class="uk-nav-header">Menu</li>
        <li v-for="i in items" :class="{ 'uk-active': i.active }"><a :href="i.url" v-text="i.title"></a></li>
        <li><a href="#docs" @click.prevent="openDocs">Docs</a></li>
        <li><a id="crm-nav-search-m" class="crm-nav-search" href="{{ routes.search_url }}"><span uk-icon="icon: search"></span> Search</a></li>
        <li><a id="crm-nav-cart-m" class="crm-nav-cart" href="{{ routes.cart_url }}"><span uk-icon="icon: cart"></span> Cart (<span data-cart-count>{{ cart.item_count }}</span>)</a></li>
        <li><a id="crm-nav-login-m" class="crm-nav-login" href="{{ routes.account_login_url }}">Log in</a></li>
        <li><a class="uk-button crm-nav-cta" href="{{ routes.root_url }}pages/connect-a-segment">Connect a segment</a></li>
      </ul>
    </div>
  </div>
</div>
<script>
  // The worker stack-loader auto-loads petite-vue (it detects [v-scope]) and mounts it.
  // Expose Nav() globally so v-scope="Nav()" resolves. Locale-aware: each language's
  // nav is a separate, remotely-editable instance of the Webflow→Shopify Nav Collection
  // (menu=main), keyed by the storefront locale. Pairs with UIkit i18n for aria strings.
  window.Nav = function () {
    return {
      items: [],
      load: function () {
        var loc = '{{ request.locale.iso_code | default: localization.language.iso_code }}';
        var self = this;
        fetch('https://cf-worker-crm-sync.yoonsunlee150.workers.dev/nav?shop={{ shop.permanent_domain }}&menu=main&locale=' + encodeURIComponent(loc))
          .then(function (r) { return r.json(); })
          .then(function (d) { self.items = (d && d.items) || []; })
          .catch(function () {});
      },
      openDocs: function () {
        if (window.crmDocsModal) { try { UIkit.offcanvas('#crm-nav-offcanvas').hide(); } catch (e) {} window.crmDocsModal.open(0); }
      }
    };
  };
</script>
